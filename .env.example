# Данные MTProto-приложения с https://my.telegram.org/apps (нужен обычный TG-аккаунт)
TG_API_ID=12345678
TG_API_HASH=abcdef0123456789abcdef0123456789

# Токен бота от @BotFather. Бот должен быть админом целевого канала
TG_BOT_TOKEN=123456:ABC-DEF...

# Куда постить: @username канала или числовой id вида -1001234567890
TG_TARGET_CHANNEL=@my_ai_digest

# Кто может управлять списком каналов через бота (/add, /remove) — id через запятую.
# Свой id узнать: напишите боту любое сообщение, он ответит "Ваш id: ...".
BOT_ADMINS=123456789

# Часовой пояс, по которому считается «вчера»
DIGEST_TZ=Europe/Moscow

# Модель для claude -p: sonnet (рекомендую), opus, haiku
CLAUDE_MODEL=sonnet

# Модель для ежедневного научного разбора статьи (paper.py). По умолчанию = CLAUDE_MODEL.
# Для более глубокого разбора можно поставить opus.
PAPER_MODEL=sonnet
# За сколько последних дней искать статьи в постах каналов для разбора.
PAPER_LOOKBACK_DAYS=3

# OAuth-токен подписки для headless/Docker. Получить: `claude setup-token`
# (валиден ~1 год). С ним claude -p работает без интерактивного логина и без
# персиста ~/.claude — идеально для контейнера. На локальной машине, где уже
# сделан интерактивный `claude` login, эту строку можно не задавать.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# ВАЖНО: НЕ добавляйте сюда ANTHROPIC_API_KEY — иначе claude -p начнёт
# списывать деньги с API-аккаунта вместо подписки. Скрипт дополнительно
# удаляет эту переменную из окружения перед вызовом.
